# Copy this file to .env locally. DO NOT commit .env (gitignored).
# In cloud routines, set these as env vars on the routine config, NOT via .env.

# ======== INDIA · DhanHQ (LIVE) ========
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
DHAN_BASE_URL=https://api.dhan.co

# ======== US · Alpaca (PAPER → LIVE after Month 2) ========
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Paper endpoint (default at start). Switch to https://api.alpaca.markets/v2 for LIVE.
ALPACA_ENDPOINT=https://paper-api.alpaca.markets/v2
ALPACA_DATA_ENDPOINT=https://data.alpaca.markets/v2

# ======== Research ========
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
# Use sonar-pro only in weekly/monthly reviews; sonar for daily.

# ======== Notifications · Telegram ========
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ======== Optional ========
# X/Twitter bearer token for read-only sentiment (v2 API)
X_BEARER_TOKEN=
# Your timezone — used for date formatting in routines
TZ=Asia/Kolkata
